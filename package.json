{
  "name": "scriptoria",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:logged-in": "playwright test --project=chromium-authenticated",
    "generate:types": "npx -y supabase gen types typescript --project-id hjiatfqphqldjqrqmxkt > src/types/database.ts"
  },
